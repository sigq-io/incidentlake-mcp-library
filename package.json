{
  "name": "@sigq-io/incidentlake-mcp-library",
  "version": "0.3.0",
  "description": "MCP server for SIGQ Incident Lake — query and manage incidents from Claude Desktop, Cursor, and other MCP clients",
  "keywords": [
    "mcp",
    "incident-management",
    "sigq",
    "claude",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigq-io/incidentlake-mcp-library.git"
  },
  "homepage": "https://github.com/sigq-io/incidentlake-mcp-library#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "bin": {
    "incidentlake-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --packages=external --outfile=dist/index.js && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
